# cpa-gateway environment (copy values into systemd unit or shell)

# Directory for keys.json (and optional API_CREDENTIALS.txt from CLIProxy)
CPA_GATEWAY_ROOT=/opt/cliproxyapi
# Or set keys path explicitly:
# CPA_GATEWAY_KEYS=/opt/cliproxyapi/keys.json
# CPA_GATEWAY_CREDS=/opt/cliproxyapi/API_CREDENTIALS.txt

CPA_GATEWAY_HOST=0.0.0.0
CPA_GATEWAY_PORT=8318

# OpenAI-compatible CLIProxyAPI base (no trailing path beyond host:port)
CPA_UPSTREAM=http://127.0.0.1:8317

# Printed by `python cpa_gateway.py add` (your public URL)
CPA_PUBLIC_BASE=https://api.example.com/cpa/v1

# Optional: force Host header when talking to upstream (usually leave empty for local CPA)
# CPA_UPSTREAM_HOST=

# Default quota for new keys (0 = unlimited)
CPA_DEFAULT_QUOTA=1000
